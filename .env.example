# PostgreSQL (postgres service)
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432

# Backend (backend service)
BACKEND_PORT=8000
APP_NAME=Inventory API
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: override backend database URL in Docker (e.g. external Postgres).
# If unset, docker-compose uses the local postgres service.
# DATABASE_URL=postgresql+psycopg2://inventory:inventory@postgres:5432/inventory_db
