# PostgreSQL (postgres service)
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432

# Backend (backend service)
BACKEND_PORT=8000
APP_NAME=Inventory API
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DATABASE_URL is set automatically in docker-compose.yml using postgres as the host.
# For local (non-Docker) backend development, use backend/.env.example instead.
